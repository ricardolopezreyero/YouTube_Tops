# Copia este archivo a .dev.vars (para `wrangler dev` local) o configuralo como
# Cloudflare Secret en produccion con `wrangler secret put <NOMBRE>`.
# NUNCA commitees el archivo real con valores.

# Obligatorio para buscar/enriquecer videos desde la YouTube Data API v3.
YOUTUBE_API_KEY=

# Opcional. Si se define, el front lo pide una vez (se guarda en localStorage) y
# el Worker lo exige en todos los endpoints /api/*. Si queda vacio, la app es abierta.
APP_PASSWORD=
