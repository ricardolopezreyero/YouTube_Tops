# Copia este archivo a .dev.vars para desarrollo local con wrangler
# NUNCA commitees .dev.vars ni .env al repositorio

# Clave de YouTube Data API v3
# Obtenerla en: console.cloud.google.com > APIs & Services > Credentials
YOUTUBE_API_KEY=

# Variables de Cloudflare (para el script de seed)
# Obtenerlas en: dash.cloudflare.com > Account ID (perfil)
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=

# El CLOUDFLARE_API_TOKEN se usa con wrangler (wrangler login o variable de entorno)
# CLOUDFLARE_API_TOKEN=
