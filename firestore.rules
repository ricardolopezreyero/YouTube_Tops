rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario: sólo el dueño puede leer y escribir su propio doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cualquier otra colección queda bloqueada por defecto
  }
}
