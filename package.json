{
  "name": "youtube-tops",
  "version": "0.1.0",
  "description": "Web app personal de un solo usuario para descubrir las mejores joyas de YouTube, saltandose el algoritmo de retencion. Stack: Cloudflare Pages + Functions + D1 + KV + Workers AI.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev public --port 8788",
    "migrate:local": "wrangler d1 migrations apply youtube_tops --local",
    "migrate:remote": "wrangler d1 migrations apply youtube_tops --remote",
    "seed": "node scripts/seed.js --remote",
    "seed:local": "node scripts/seed.js --local",
    "deploy": "wrangler pages deploy public"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
